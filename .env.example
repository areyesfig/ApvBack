# Entorno: development | production
# En production CORS_ORIGINS es obligatorio (no usar *)
ENV=development
CORS_ORIGINS=*

# Producción: orígenes permitidos separados por coma (HTTPS)
# CORS_ORIGINS=https://app.tudominio.com,https://www.tudominio.com

# Refresco de indicadores en background (segundos; default 6 horas)
# APV_INDICADORES_REFRESH_SECONDS=21600

# Indicadores Chile (opcional; por defecto se usan mindicador.cl)
# APV_UF=38500
# APV_UTM=66362
# APV_UTA=796344
# APV_ANO_TRIBUTARIO=2026
# APV_TASA_COTIZACIONES=0.205
